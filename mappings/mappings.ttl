@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#> .
@prefix fno: <https://w3id.org/function/ontology#> .
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix : <http://mapping.example.com/> .
@prefix aeros: <http://w3id.org/aeros/continuum#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix schema: <http://schema.org/> .

:rules_000 rdf:type void:Dataset ;
	void:exampleResource :map_users_000, :map_roles_000, :map_organizations_000, :map_membership_000 .

:map_users_000 rml:logicalSource :source_000 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "users" ;
	rr:subjectMap :s_000 ;
	rr:predicateObjectMap :pom_000, :pom_001, :pom_002, :pom_003, :pom_004 .

:source_000 rdf:type rml:LogicalSource ;
	rml:source "http://ldap-collector:63300/ldap.json" ;
	rml:iterator "$.users[*]" ;
	rml:referenceFormulation ql:JSONPath .

:s_000 rdf:type rr:SubjectMap ;
	rr:template "http://w3id.org/aeros/continuum#{attributes.uid}" .

:pom_000 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_000 ;
	rr:objectMap :om_000 .

:pm_000 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

:om_000 rdf:type rr:ObjectMap ;
	rr:constant aeros:User ;
	rr:termType rr:IRI .

:pom_001 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_001 ;
	rr:objectMap :om_001 .

:pm_001 rdf:type rr:PredicateMap ;
	rr:constant foaf:firstName .

:om_001 rdf:type rr:ObjectMap ;
	rml:reference "attributes.givenName" ;
	rr:termType rr:Literal ;
	rr:datatype <http://www.w3.org/2001/XMLSchema#string> .

:pom_002 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_002 ;
	rr:objectMap :om_002 .

:pm_002 rdf:type rr:PredicateMap ;
	rr:constant foaf:lastName .

:om_002 rdf:type rr:ObjectMap ;
	rml:reference "attributes.sn" ;
	rr:termType rr:Literal ;
	rr:datatype <http://www.w3.org/2001/XMLSchema#string> .

:pom_003 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_003 ;
	rr:objectMap :om_003 .

:pm_003 rdf:type rr:PredicateMap ;
	rr:constant schema:email .

:om_003 rdf:type rr:ObjectMap ;
	rml:reference "attributes.mail" ;
	rr:termType rr:Literal ;
	rr:datatype <http://www.w3.org/2001/XMLSchema#string> .

:pom_004 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_004 ;
	rr:objectMap :om_004 .

:pm_004 rdf:type rr:PredicateMap ;
	rr:constant aeros:username .

:om_004 rdf:type rr:ObjectMap ;
	rml:reference "attributes.uid" ;
	rr:termType rr:Literal ;
	rr:datatype <http://www.w3.org/2001/XMLSchema#string> .

:map_roles_000 rml:logicalSource :source_001 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "roles" ;
	rr:subjectMap :s_001 ;
	rr:predicateObjectMap :pom_005 .

:source_001 rdf:type rml:LogicalSource ;
	rml:source "http://ldap-collector:63300/ldap.json" ;
	rml:iterator "$.roles[*]" ;
	rml:referenceFormulation ql:JSONPath .

:s_001 rdf:type rr:SubjectMap ;
	rr:template "http://www.w3.org/ns/org#{attributes.cn}" .

:pom_005 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_005 ;
	rr:objectMap :om_005 .

:pm_005 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

:om_005 rdf:type rr:ObjectMap ;
	rr:constant org:Role ;
	rr:termType rr:IRI .

:map_organizations_000 rml:logicalSource :source_002 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "organizations" ;
	rr:subjectMap :s_002 ;
	rr:predicateObjectMap :pom_006, :pom_007 .

:source_002 rdf:type rml:LogicalSource ;
	rml:source "http://ldap-collector:63300/ldap.json" ;
	rml:iterator "$.groups[*]" ;
	rml:referenceFormulation ql:JSONPath .

:s_002 rdf:type rr:SubjectMap ;
	rr:template "http://www.w3.org/ns/org#{attributes.cn}" .

:pom_006 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_006 ;
	rr:objectMap :om_006 .

:pm_006 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

:om_006 rdf:type rr:ObjectMap ;
	rr:constant org:Organization ;
	rr:termType rr:IRI .

:pom_007 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_007 ;
	rr:objectMap :om_007 .

:pm_007 rdf:type rr:PredicateMap ;
	rr:constant dct:title .

:om_007 rdf:type rr:ObjectMap ;
	rml:reference "attributes.cn" ;
	rr:termType rr:Literal ;
	rr:datatype <http://www.w3.org/2001/XMLSchema#string> .

:map_membership_000 rml:logicalSource :source_003 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "membership" ;
	rr:subjectMap :s_003 ;
	rr:predicateObjectMap :pom_008, :pom_009, :pom_010, :pom_011 .

:source_003 rdf:type rml:LogicalSource ;
	rml:source "http://ldap-collector:63300/ldap.json" ;
	rml:iterator "$.memberships[*]" ;
	rml:referenceFormulation ql:JSONPath .

:s_003 rdf:type rr:SubjectMap ;
	rr:template "http://www.w3.org/ns/org#membership_{memberUid}_{role_cn}" .

:pom_008 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_008 ;
	rr:objectMap :om_008 .

:pm_008 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

:om_008 rdf:type rr:ObjectMap ;
	rr:constant org:Membership ;
	rr:termType rr:IRI .

:pom_009 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_009 ;
	rr:objectMap :om_009 .

:pm_009 rdf:type rr:PredicateMap ;
	rr:constant org:member .

:pom_010 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_010 ;
	rr:objectMap :om_010 .

:pm_010 rdf:type rr:PredicateMap ;
	rr:constant org:role .

:pom_011 rdf:type rr:PredicateObjectMap ;
	rr:predicateMap :pm_011 ;
	rr:objectMap :om_011 .

:pm_011 rdf:type rr:PredicateMap ;
	rr:constant org:organization .

:om_009 rdf:type rr:ObjectMap ;
	rr:parentTriplesMap :map_users_000 ;
	rr:joinCondition :jc_000 .

:jc_000 rr:child "memberUid" ;
	rr:parent "attributes.uid" .

:om_010 rdf:type rr:ObjectMap ;
	rr:parentTriplesMap :map_roles_000 ;
	rr:joinCondition :jc_001 .

:jc_001 rr:child "role_cn" ;
	rr:parent "attributes.cn" .

:om_011 rdf:type rr:ObjectMap ;
	rr:parentTriplesMap :map_organizations_000 ;
	rr:joinCondition :jc_002 .

:jc_002 rr:child "group_cn" ;
	rr:parent "attributes.cn" .

